{
  "name": "pos-inventory-system",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron:start": "electron .",
    "electron:build": "electron-builder --win"
  },
  "build": {
    "appId": "com.supertech.pos",
    "productName": "Supertech POS System",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "asar": true,
    "files": [
      "**/*",
      "!dist/*",
      "!backups/*",
      "!pos_database.sqlite*",
      "!sessions.sqlite",
      "!.env*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "connect-sqlite3": "^0.9.16",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "node-cron": "^4.2.1",
    "nodemon": "^3.1.14",
    "wait-on": "^9.0.5"
  }
}
