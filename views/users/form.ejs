<%- include('../partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-lg rounded-4">
            <div class="card-header border-bottom border-secondary bg-transparent py-3 text-center">
                <h4 class="mb-0 fw-semibold"><i class="bi bi-person-plus me-2"></i><%= title %></h4>
            </div>
            <div class="card-body p-5">
                <form action="<%= editUser ? '/users/edit/' + editUser.id : '/users/create' %>" method="POST">
                    <div class="mb-4">
                        <label class="form-label text-muted">Username</label>
                        <input type="text" name="username" class="form-control form-control-lg" required 
                               value="<%= editUser ? editUser.username : '' %>" <%= editUser ? 'readonly' : '' %>>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label text-muted"><%= editUser ? 'New Password (leave blank to keep current)' : 'Password' %></label>
                        <input type="password" name="password" class="form-control form-control-lg" <%= editUser ? '' : 'required' %>>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted">Role</label>
                        <select name="role" class="form-select form-select-lg" required>
                            <option value="staff" <%= editUser && editUser.role === 'staff' ? 'selected' : '' %>>Staff</option>
                            <option value="admin" <%= editUser && editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted">Staff Permissions <small>(only applies to staff role)</small></label>
                        <div class="d-flex flex-wrap gap-3 mt-2">
                            <%
                                var availablePerms = ['add_product', 'edit_product', 'view_stock'];
                                var currentPerms = editUser ? (Array.isArray(editUser.permissions) ? editUser.permissions : JSON.parse(editUser.permissions || '[]')) : [];
                            %>
                            <% availablePerms.forEach(function(perm) { %>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="permissions" value="<%= perm %>" id="perm_<%= perm %>" 
                                           <%= currentPerms.indexOf(perm) !== -1 ? 'checked' : '' %>>
                                    <label class="form-check-label" for="perm_<%= perm %>"><%= perm.replace(/_/g, ' ') %></label>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/users" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm"><i class="bi bi-check-circle me-1"></i>Save User</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
