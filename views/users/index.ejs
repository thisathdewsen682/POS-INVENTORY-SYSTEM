<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold">User Management</h2>
    <a href="/users/create" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-person-plus me-2"></i>Add User</a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-octagon me-2"></i><strong>Error:</strong> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Permissions</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(users.length === 0) { %>
                        <tr><td colspan="5" class="text-center py-4 text-muted">No users found.</td></tr>
                    <% } %>
                    <% users.forEach(function(u) { %>
                    <tr>
                        <td class="ps-4 text-muted">#<%= u.id %></td>
                        <td class="fw-medium">
                            <i class="bi bi-person-circle me-2 <%= u.is_active === 0 ? 'text-muted' : '' %>"></i>
                            <span class="<%= u.is_active === 0 ? 'text-decoration-line-through text-muted' : '' %>"><%= u.username %></span>
                        </td>
                        <td>
                            <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-info' %> rounded-pill px-3"><%= u.role.toUpperCase() %></span>
                        </td>
                        <td>
                            <% if (u.is_active === 0) { %>
                                <span class="badge bg-secondary rounded-pill px-3">Inactive</span>
                            <% } else { %>
                                <span class="badge bg-success rounded-pill px-3">Active</span>
                            <% } %>
                        </td>
                        <td>
                            <% var perms = JSON.parse(u.permissions || '[]'); %>
                            <% if (perms.length > 0) { %>
                                <% perms.forEach(function(p) { %>
                                    <span class="badge bg-secondary me-1"><%= p %></span>
                                <% }) %>
                            <% } else { %>
                                <span class="text-muted">—</span>
                            <% } %>
                        </td>
                        <td class="text-end pe-4">
                            <a href="/users/edit/<%= u.id %>" class="btn btn-sm btn-outline-info rounded-pill px-3 me-1"><i class="bi bi-pencil"></i></a>
                            <% if (u.username !== 'admin') { %>
                            <form action="/users/toggle-status/<%= u.id %>" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-sm <%= u.is_active === 0 ? 'btn-success' : 'btn-warning' %> rounded-pill px-3 me-1" title="<%= u.is_active === 0 ? 'Activate' : 'Deactivate' %>">
                                    <i class="bi <%= u.is_active === 0 ? 'bi-person-check' : 'bi-person-dash' %>"></i>
                                </button>
                            </form>
                            <form action="/users/delete/<%= u.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this user? If they have sales, you should deactivate them instead.');">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="bi bi-trash"></i></button>
                            </form>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
