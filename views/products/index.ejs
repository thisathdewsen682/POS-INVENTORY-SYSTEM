<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold">Products</h2>
    <a href="/products/create" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-plus-lg me-2"></i>Add Product</a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Code</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Cost</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(products.length === 0) { %>
                        <tr><td colspan="7" class="text-center py-4 text-muted">No products found.</td></tr>
                    <% } %>
                    <% products.forEach(function(product) { %>
                    <tr>
                        <td class="ps-4 text-muted">#<%= String(product.id).padStart(4, '0') %></td>
                        <td class="fw-medium"><%= product.name %></td>
                        <td><span class="badge bg-secondary"><%= product.category_name %></span></td>
                        <td class="text-muted"><%= currencySymbol %><%= (product.cost_price || 0).toFixed(2) %></td>
                        <td class="text-success fw-bold"><%= currencySymbol %><%= product.price.toFixed(2) %></td>
                        <td>
                            <span class="badge <%= product.stock_quantity <= 5 ? 'bg-danger' : 'bg-success' %> rounded-pill px-3 py-2">
                                <%= product.stock_quantity %>
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <a href="/products/edit/<%= product.id %>" class="btn btn-sm btn-outline-info rounded-pill px-3 me-2"><i class="bi bi-pencil"></i></a>
                            <form action="/products/delete/<%= product.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this product?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
