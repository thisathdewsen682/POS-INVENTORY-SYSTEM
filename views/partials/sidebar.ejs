<div class="border-end border-secondary" id="sidebar-wrapper" style="width: 250px; min-height: 100vh;">
    <div class="sidebar-heading text-center py-4 fs-4 fw-bold text-gradient border-bottom border-secondary mb-3">
        <% if (logoPath) { %><img src="<%= logoPath %>" alt="Logo" style="max-height: 30px; vertical-align: middle;" class="me-2"><% } else { %><i class="bi bi-shop me-2"></i><% } %><%= shopName %>
    </div>
    <div class="list-group list-group-flush px-2">
        <a href="/dashboard" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
        
        <a href="/billing" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-cart me-2"></i>Billing</a>
        
        <% 
            var perms = [];
            if (user && user.permissions) {
                try { perms = JSON.parse(user.permissions); } catch(e) {}
            }
            var isAdmin = user.role === 'admin';
            var canViewStock = isAdmin || perms.indexOf('view_stock') !== -1;
            var canAddProduct = isAdmin || perms.indexOf('add_product') !== -1;
            var canEditProduct = isAdmin || perms.indexOf('edit_product') !== -1;
        %>

        <% if (canViewStock || isAdmin) { %>
            <div class="nav-heading text-muted mt-3 mb-1 px-3 fs-7 text-uppercase fw-semibold">Inventory</div>
            <% if (canViewStock) { %>
            <a href="/stock/overview" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-box-seam me-2"></i>Current Stock</a>
            <% } %>
            
            <% if (isAdmin) { %>
            <a href="/categories" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-tags me-2"></i>Categories</a>
            <a href="/products" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-box me-2"></i>Products</a>
            <a href="/stock" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-arrow-left-right me-2"></i>Stock Update</a>
            <% } %>
        <% } %>
        
        <% if (isAdmin) { %>
            <div class="nav-heading text-muted mt-3 mb-1 px-3 fs-7 text-uppercase fw-semibold">Reports</div>
            <a href="/sales" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-receipt me-2"></i>Sales History</a>
            <a href="/reports" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-graph-up me-2"></i>Reports</a>
            
            <div class="nav-heading text-muted mt-3 mb-1 px-3 fs-7 text-uppercase fw-semibold">System</div>
            <a href="/users" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-people me-2"></i>Users</a>
            <a href="/settings" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-gear me-2"></i>Settings</a>
            <a href="/backup" class="list-group-item list-group-item-action bg-transparent border-0 rounded my-1"><i class="bi bi-hdd me-2"></i>Backups</a>
        <% } %>
    </div>
</div>
