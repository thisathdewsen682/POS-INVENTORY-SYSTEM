<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= shopName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
        })();
    </script>
</head>
<body class="bg-dark text-light">
    <% if (user) { %>
    <div class="d-flex" id="wrapper">
        <%- include('sidebar') %>
        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary px-4 py-3 shadow-sm d-flex justify-content-between align-items-center flex-nowrap shrink-0 w-100 w-full mb-4">
                <button class="btn btn-outline-light d-md-none me-3" id="menu-toggle"><i class="bi bi-list"></i></button>
                <div class="fs-4 fw-bold text-gradient pe-none"><%= title %></div>
                <div class="d-flex align-items-center">
                    <button id="theme-toggle" class="btn btn-outline-secondary btn-sm me-3 rounded-circle" style="width: 32px; height: 32px; padding: 0;">
                        <i class="bi bi-moon-stars-fill" id="theme-icon"></i>
                    </button>
                    <span class="me-3 d-none d-md-inline">Welcome, <strong><%= user.username %></strong> (<%= user.role %>)</span>
                    <a href="/logout" class="btn btn-sm btn-danger rounded-pill px-3"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
                </div>
            </nav>
            <div class="container-fluid px-4 pb-5">
                <% if (error) { %>
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <%= error %>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if (success) { %>
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <%= success %>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
    <% } %>
