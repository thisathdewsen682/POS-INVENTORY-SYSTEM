<%- include('../partials/header') %>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-lg rounded-4">
            <div class="card-header border-bottom border-secondary bg-transparent py-4 text-center">
                <h4 class="mb-0 fw-semibold text-gradient"><i class="bi bi-cart me-2"></i>Point of Sale (Billing)</h4>
            </div>
            <div class="card-body p-0">
                <div class="row g-0">
                    <!-- Left: Products List -->
                    <div class="col-lg-7 border-end border-secondary p-4">
                        <div class="mb-3">
                            <div class="input-group input-group-lg">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" id="search-product" class="form-control" placeholder="Search products by name or category...">
                            </div>
                        </div>
                        <div class="row row-cols-1 row-cols-md-2 g-3" id="product-list" style="max-height: 60vh; overflow-y: auto;">
                            <% products.forEach(function(p) { %>
                                <div class="col product-card-container" data-name="<%= p.name.toLowerCase() %>" data-category="<%= (p.category_name || '').toLowerCase() %>">
                                    <div class="card border-secondary h-100 product-card" 
                                         style="cursor: pointer; transition: transform 0.2s;"
                                         onclick="addToCart(<%= p.id %>, '<%= p.name.replace(/'/g, "\\'") %>', <%= p.price %>, <%= p.stock_quantity %>)">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h6 class="mb-1 fw-bold text-truncate" style="max-width: 70%;"><%= p.name %></h6>
                                                <span class="badge bg-primary"><%= currencySymbol %><%= p.price.toFixed(2) %></span>
                                            </div>
                                            <p class="text-muted small mb-0 mt-2"><i class="bi bi-tag me-1"></i><%= p.category_name %></p>
                                            <div class="mt-2 text-end">
                                                <span class="badge <%= p.stock_quantity <= 5 ? 'bg-danger' : 'bg-success' %> rounded-pill">
                                                    Stock: <%= p.stock_quantity %>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                    
                    <!-- Right: Cart -->
                    <div class="col-lg-5 p-4 d-flex flex-column">
                        <h5 class="mb-3"><i class="bi bi-bag-check me-2"></i>Current Order</h5>
                        <div class="table-responsive flex-grow-1" style="min-height: 250px; max-height: 40vh; overflow-y: auto;">
                            <table class="table table-hover mb-0 align-middle" id="cart-table">
                                <thead class="sticky-top">
                                    <tr>
                                        <th>Item</th>
                                        <th style="width:70px;">Qty</th>
                                        <th style="width:80px;">Disc ($)</th>
                                        <th class="text-end">Total</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="cart-body">
                                    <tr><td colspan="5" class="text-center text-muted py-5"><i class="bi bi-cart-x fs-1 d-block mb-2 opacity-50"></i>Cart is empty</td></tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="mt-auto border-top border-secondary pt-3">
                            <div class="row mb-2">
                                <div class="col-6 text-muted">Subtotal</div>
                                <div class="col-6 text-end fw-bold" id="cart-subtotal">$0.00</div>
                            </div>
                            <div class="row mb-2 align-items-center">
                                <div class="col-4 text-muted">Discount</div>
                                <div class="col-4">
                                    <select id="bill-discount-type" class="form-select form-select-sm">
                                        <option value="flat">Flat ($)</option>
                                        <option value="percent">Percent (%)</option>
                                    </select>
                                </div>
                                <div class="col-4">
                                    <input type="number" id="bill-discount" class="form-control form-control-sm text-end" value="0" min="0" step="0.01">
                                </div>
                            </div>
                            <div class="row align-items-center mt-3 bg-primary bg-opacity-25 rounded-3 p-3 border border-primary border-opacity-50">
                                <div class="col-6 fs-5 fw-bold">TOTAL</div>
                                <div class="col-6 text-end fs-3 fw-bold text-success" id="cart-total">$0.00</div>
                            </div>
                            
                            <button class="btn btn-success w-100 py-3 mt-4 rounded-pill shadow fs-5 fw-bold" id="checkout-btn" disabled>
                                <i class="bi bi-bag-check me-2"></i>Checkout & Print
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
<script src="/js/billing.js"></script>
