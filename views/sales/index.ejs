<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold">Sales History</h2>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-dark mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>Invoice Number</th>
                        <th>Staff</th>
                        <th>Items</th>
                        <th>Total Amount</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(sales.length === 0) { %>
                        <tr><td colspan="6" class="text-center py-4 text-muted">No sales found.</td></tr>
                    <% } %>
                    <% sales.forEach(sale => { %>
                    <tr>
                        <td class="ps-4 text-muted"><%= new Date(sale.date).toLocaleString() %></td>
                        <td class="fw-medium text-info"><%= sale.invoice_number %></td>
                        <td><span class="badge bg-secondary"><i class="bi bi-person me-1"></i><%= sale.staff_name %></span></td>
                        <td><%= sale.item_count %></td>
                        <td class="text-success fw-bold">$<%= sale.total.toFixed(2) %></td>
                        <td class="text-end pe-4">
                            <a href="/sales/detail/<%= sale.id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2"><i class="bi bi-eye"></i> View</a>
                            <a href="/invoices/print/<%= sale.id %>" target="_blank" class="btn btn-sm btn-outline-secondary rounded-pill px-3"><i class="bi bi-printer"></i></a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
