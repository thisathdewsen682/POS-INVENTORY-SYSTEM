<%- include('../partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-lg rounded-4">
            <div class="card-header border-bottom border-secondary bg-transparent py-3 text-center">
                <h4 class="mb-0 fw-semibold"><i class="bi bi-tag me-2"></i><%= title %></h4>
            </div>
            <div class="card-body p-5">
                <form action="<%= category ? '/categories/edit/' + category.id : '/categories/create' %>" method="POST">
                    <div class="mb-4">
                        <label class="form-label text-muted">Category Name</label>
                        <input type="text" name="name" class="form-control form-control-lg bg-dark text-light border-secondary" required value="<%= category ? category.name : '' %>" autofocus>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/categories" class="btn btn-outline-secondary rounded-pill px-4 text-light">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm"><i class="bi bi-check-circle me-1"></i>Save Category</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
