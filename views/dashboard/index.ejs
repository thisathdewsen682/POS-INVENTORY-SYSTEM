<%- include('../partials/header') %>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 bg-dark position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 text-uppercase fs-7 fw-semibold">Today's Revenue</p>
                        <h2 class="mb-0 text-success fw-bold">$<%= todaysRevenue.toFixed(2) %></h2>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                        <i class="bi bi-currency-dollar fs-3"></i>
                    </div>
                </div>
            </div>
            <div class="position-absolute bottom-0 start-0 w-100 bg-success" style="height: 4px;"></div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 bg-dark position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 text-uppercase fs-7 fw-semibold">Total Products</p>
                        <h2 class="mb-0 text-primary fw-bold"><%= totalProducts %></h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                        <i class="bi bi-box-seam fs-3"></i>
                    </div>
                </div>
            </div>
            <div class="position-absolute bottom-0 start-0 w-100 bg-primary" style="height: 4px;"></div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 bg-dark position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 text-uppercase fs-7 fw-semibold">Low Stock Items</p>
                        <h2 class="mb-0 <%= lowStockCount > 0 ? 'text-danger' : 'text-success' %> fw-bold"><%= lowStockCount %></h2>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                        <i class="bi bi-exclamation-triangle fs-3"></i>
                    </div>
                </div>
            </div>
            <div class="position-absolute bottom-0 start-0 w-100 bg-danger" style="height: 4px;"></div>
        </div>
    </div>
</div>

<% if (lowStockProducts.length > 0) { %>
<div class="card shadow-sm border-0 mb-4 rounded-3">
    <div class="card-header bg-danger bg-opacity-10 border-danger border-opacity-25 py-3 rounded-top-3">
        <h5 class="mb-0 text-danger fw-semibold"><i class="bi bi-shield-exclamation me-2"></i>Low Stock Alerts</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-dark mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Product Name</th>
                        <th>Category</th>
                        <th>Current Stock</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% lowStockProducts.forEach(product => { %>
                    <tr>
                        <td class="ps-4 fw-medium"><%= product.name %></td>
                        <td><span class="badge bg-secondary"><%= product.category_name %></span></td>
                        <td>
                            <span class="badge bg-danger fs-6 px-3 py-2 rounded-pill"><%= product.stock_quantity %></span>
                        </td>
                        <td class="text-end pe-4">
                            <% if(user.role === 'admin') { %>
                                <a href="/stock" class="btn btn-sm btn-outline-light rounded-pill px-3">Update Stock</a>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<% } else { %>
<div class="card shadow-sm border-0 mb-4 text-center rounded-3">
    <div class="card-body p-5">
        <div class="display-1 text-success mb-3 opacity-50"><i class="bi bi-check-circle"></i></div>
        <h4 class="text-muted mb-0">Inventory is healthy! No low stock alerts.</h4>
    </div>
</div>
<% } %>

<%- include('../partials/footer') %>
